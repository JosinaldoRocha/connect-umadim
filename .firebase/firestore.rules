rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function getUserData() {
      let doc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return doc.data;
    }

    function isLeader() {
      let user = getUserData();
      return user != null
          && (user.umadimFunction.title != 'Membro'
              || user.localFunction.title != 'Membro');
    }

    function isLeaderOnlyType(postType) {
      return postType in ['notice', 'event', 'poll'];
    }

    // ── Usuários ────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && isOwner(userId);
    }

    // ── Posts ───────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if isAuth();

      allow create: if isAuth()
          && request.resource.data.authorId == request.auth.uid
          && (
            isLeaderOnlyType(request.resource.data.type)
              ? isLeader()
              : true
          );

      allow update: if isAuth() && (
        isOwner(resource.data.authorId)
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['likeIds', 'presenceIds', 'pollOptions', 'commentCount'])
      );

      allow delete: if isAuth()
          && (isOwner(resource.data.authorId) || isLeader());

      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth()
            && request.resource.data.authorId == request.auth.uid;
        allow update: if isAuth()
            && isOwner(resource.data.authorId);
        allow delete: if isAuth()
            && (isOwner(resource.data.authorId) || isLeader());
      }
    }

    // ── Stories ─────────────────────────────────────────────────
    match /stories/{storyId} {
      allow read: if isAuth();

      allow create: if isAuth()
          && request.resource.data.authorId == request.auth.uid;

      allow update: if isAuth() && (
        isOwner(resource.data.authorId)
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['viewerIds'])
      );

      allow delete: if isAuth() && isOwner(resource.data.authorId);
    }

    // ── Líderes ──────────────────────────────────────────────────
    match /leaders/{leaderId} {
      allow read: if isAuth();
      allow write: if isAuth() && isLeader();
    }

    // ── Versículos ───────────────────────────────────────────────
    match /verses/{verseId} {
      allow read: if isAuth();
      allow write: if isAuth() && isLeader();
    }

    // ── Eventos ──────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if isAuth();
      allow write: if isAuth() && isLeader();
    }
  }
}